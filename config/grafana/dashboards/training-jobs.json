      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      },
      "title": "Job Inventory",
      "type": "table",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "veltrix_training_job_steps_total",
        "instant": true,
        "format": "table",
        "refId": "A"
      }]
    }
