{
  "annotations": {
    "list": [
      {
        "name": "Veltrix Alerts",
        "datasource": { "type": "datasource", "uid": "-- Grafana --" },
        "enable": true,
        "iconColor": "red",
        "target": { "type": "dashboard", "limit": 100, "matchAny": false, "tags": [], "alertName": "" }
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 10, "spanNulls": false },
          "unit": "percentunit",
          "min": 0.9,
          "max": 1
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "min"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "SLO Attainment vs Target",
      "type": "timeseries",
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "veltrix_slo_attainment_ratio",
          "legendFormat": "attainment {{slo}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "veltrix_slo_target_ratio",
          "legendFormat": "target {{slo}}",
          "refId": "B"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0.2 },
            { "color": "green", "value": 0.5 }
          ]},
          "unit": "percentunit",
          "min": 0,
          "max": 1
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true
      },
      "title": "Error Budget Remaining",
      "type": "bargauge",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "veltrix_slo_error_budget_remaining_ratio",
        "legendFormat": "{{slo}}",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 1 },
            { "color": "red", "value": 5 }
          ]},
          "unit": "short"
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "id": 3,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "title": "Violations (last 24h)",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum(increase(veltrix_slo_violations_total[24h]))",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 15, "spanNulls": false },
          "unit": "ops"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 6, "y": 8 },
      "id": 4,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Violations by Severity",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum by (severity)(rate(veltrix_slo_violations_total[5m]))",
        "legendFormat": "{{severity}}",
        "refId": "A"
      }]
    },
    {
      "gridPos": { "h": 8, "w": 6, "x": 18, "y": 8 },
      "id": 5,
      "options": {
        "showOptions": "current",
        "maxItems": 20,
        "sortOrder": 1,
        "stateFilter": { "firing": true, "pending": true, "noData": false, "normal": true },
        "folderId": null,
        "tags": []
      },
      "title": "Active Alerts",
      "type": "alertlist"
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["veltrix", "slo"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 2,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-15m", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Veltrix \u2014 SLOs & Alerts",
  "uid": "veltrix-slo-alerts",
  "version": 1
}
