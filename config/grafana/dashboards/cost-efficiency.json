{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "blue", "value": null }] },
          "unit": "currencyUSD",
          "decimals": 2
        }
      },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      },
      "title": "Cluster Spend (last hour)",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "increase(veltrix_cluster_spend_usd_total[1h])",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 50 },
            { "color": "red", "value": 100 }
          ]},
          "unit": "currencyUSD",
          "decimals": 2
        },
        "overrides": [
          {
            "matcher": { "id": "byType", "options": "number" },
            "properties": [{ "id": "displayName", "value": "${__field.displayName} /hr" }]
          }
        ]
      },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "id": 2,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "title": "Burn Rate",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "veltrix_cost_burn_rate_usd_per_hour",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 0 },
            { "color": "yellow", "value": 5 },
            { "color": "green", "value": 10 }
          ]},
          "unit": "currencyUSD",
          "decimals": 2
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 3,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "horizontal",
        "showThresholdLabels": false,
        "showThresholdMarkers": true
      },
      "title": "Hourly Budget Headroom",
      "type": "gauge",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "veltrix_cost_budget_target_usd{window=\"hourly\"} - increase(veltrix_cluster_spend_usd_total[1h])",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "currencyUSD",
          "decimals": 2
        }
      },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "id": 4,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "pieType": "donut",
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] },
        "tooltip": { "mode": "single" }
      },
      "title": "Spend by Workload",
      "type": "piechart",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum by (workload_type)(rate(veltrix_gpu_spend_usd_total[5m])) * 3600",
        "legendFormat": "{{workload_type}}",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 25,
            "spanNulls": false,
            "stacking": { "mode": "normal", "group": "A" }
          },
          "unit": "currencyUSD",
          "decimals": 2,
          "min": 0
        }
      },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 8 },
      "id": 5,
      "options": {
        "legend": { "displayMode": "table", "placement": "right", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      },
      "title": "Spend by GPU Model",
      "type": "timeseries",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "sum by (gpu_model)(rate(veltrix_gpu_spend_usd_total[5m])) * 3600",
        "legendFormat": "{{gpu_model}}",
        "refId": "A"
      }]
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [
            { "color": "green", "value": null },
            { "color": "yellow", "value": 5 },
            { "color": "red", "value": 20 }
          ]},
          "unit": "currencyUSD",
          "decimals": 2
        }
      },
      "gridPos": { "h": 4, "w": 8, "x": 0, "y": 16 },
      "id": 6,
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "auto"
      },
      "title": "Idle Cost (USD/hr)",
      "type": "stat",
      "targets": [{
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "expr": "count(veltrix_gpu_utilization_percent{workload_type=\"\"}) * avg(veltrix_gpu_hourly_price_usd)",
        "refId": "A"
      }]
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["veltrix", "cost"],
  "templating": {
    "list": [
      {
        "current": { "selected": false, "text": "Prometheus", "value": "Prometheus" },
        "hide": 2,
        "includeAll": false,
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "type": "datasource"
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Veltrix \u2014 Cost & Efficiency",
  "uid": "veltrix-cost-efficiency",
  "version": 1
}
